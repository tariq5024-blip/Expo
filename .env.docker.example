# Docker Compose: copy to .env.docker and set secrets. Images: Dockerfile.app (Node 20) + Dockerfile.web (nginx stable-alpine).
# Rebuild after lockfile changes: docker compose build --no-cache app web
MONGO_URI=mongodb://mongo:27017/expo
LOCAL_FALLBACK_MONGO_URI=mongodb://mongo:27017/expo
ALLOW_INMEMORY_FALLBACK=false
SHADOW_DB_NAME=expo_shadow
ENABLE_BACKUP_SCHEDULER=true
PORT=5000
NODE_ENV=production
CORS_ORIGIN=http://localhost:3000
SESSION_MAX_AGE_MS=2592000000
COOKIE_SECURE=auto
COOKIE_SAMESITE=lax
COOKIE_SECRET=replace_with_secure_random_value
EMAIL_CONFIG_ENCRYPTION_KEY=replace_with_64_hex_chars_or_base64_32_bytes
PUBLIC_BASE_URL=http://localhost:5000
# Optional: absolute URL of the web app for links in emails (gate pass “open in app”), e.g. https://expo.example.com
# PUBLIC_APP_URL=http://localhost:3000
# CLIENT_URL=http://localhost:3000
EMERGENCY_RESET_SECRET=replace_with_secure_random_value
ENABLE_CSRF=true
TRUST_PROXY_HOPS=1
MAX_BACKUP_UPLOAD_MB=1024
MONGO_BIND_ADDRESS=127.0.0.1
SEED_DEFAULTS=false
# Optional SMTP (often configured in-app); required if you set these before first UI save
# SMTP_HOST=smtp.gmail.com
# SMTP_PORT=587
# SMTP_EMAIL=
# SMTP_PASSWORD=
# FROM_NAME=Expo Stores
# Auth mode: HTTP-only cookies only (JWT is not used)
# Backup mode: mongodump/mongorestore archive flow
