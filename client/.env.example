# Used only by Vite dev server proxy (npm run dev in client/).
# Production builds do not embed these: the app calls /api on the same origin.
# Prefer 127.0.0.1 on Linux if you see proxy ECONNREFUSED with localhost (::1 vs IPv4).
VITE_API_HOST=127.0.0.1
VITE_API_PORT=5000

# If backend runs on a different port (e.g. 5001), set:
# VITE_API_PORT=5001

# Production / client laptop: build with `npm run build` then serve via Node or Nginx
# so /api and /uploads proxy to the API. See ../DEPLOY_CHECKLIST.md and ../README_LOCAL.md.
