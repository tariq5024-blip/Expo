MONGO_URI=mongodb+srv://username:password@cluster.mongodb.net/dbname
JWT_SECRET=change_this_to_a_secure_random_string
PORT=5000
SESSION_MAX_AGE_MS=2592000000
COOKIE_SECURE=false
COOKIE_SECRET=change_me_to_random_32_bytes
EMERGENCY_RESET_SECRET=emergency_unlock
ENABLE_CSRF=true
SEED_DEFAULTS=true

# Default accounts when SEED_DEFAULTS=true
# superadmin@expo.com / superadmin123
# scy@expo.com / admin123
# it@expo.com / admin123
# noc@expo.com / admin123

# Email Configuration
SMTP_HOST=smtp.gmail.com
SMTP_PORT=587
SMTP_EMAIL=your_email@gmail.com
SMTP_PASSWORD=your_app_specific_password
FROM_NAME=Expo Stores
