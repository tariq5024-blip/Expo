# Local/server runtime example
MONGO_URI=mongodb://127.0.0.1:27017/expo
LOCAL_FALLBACK_MONGO_URI=mongodb://127.0.0.1:27017/expo
ALLOW_INMEMORY_FALLBACK=false
SHADOW_DB_NAME=expo_shadow
ENABLE_BACKUP_SCHEDULER=true

PORT=5000
NODE_ENV=development
# Browser origin users type (scheme+host+port). In production this MUST match exactly.
CORS_ORIGIN=http://localhost:3000
PUBLIC_BASE_URL=http://localhost:5000
# Optional browser URL used in email deep links (gate pass, password reset, open-app links).
# Forgot-password also accepts the browser’s current origin when it matches CORS_ORIGIN or (in non-production) a private LAN IP so links work at http://YOUR_LAN_IP:5173.
# Should match where users open the app (e.g. Vite dev server). Falls back to first CORS_ORIGIN.
# PUBLIC_APP_URL=http://localhost:5173
# CLIENT_URL=http://localhost:5173
# Password reset link lifetime in ms (default 1 hour).
# PASSWORD_RESET_EXPIRES_MS=3600000

SESSION_MAX_AGE_MS=2592000000
COOKIE_SECURE=auto
COOKIE_SAMESITE=lax
COOKIE_SECRET=replace_with_secure_random_value
EMAIL_CONFIG_ENCRYPTION_KEY=replace_with_64_hex_chars_or_base64_32_bytes
EMERGENCY_RESET_SECRET=replace_with_secure_random_value
ENABLE_CSRF=true
TRUST_PROXY_HOPS=1
# Max JSON body size for API (e.g. 5mb, 10mb). Defaults: 5mb prod, 10mb dev.
# JSON_BODY_LIMIT=5mb
# Set true only when the site is served over HTTPS end-to-end (enables HSTS).
# ENABLE_HSTS=false
# Cap login attempts per IP+identifier per window (default 60 prod, 200 dev).
# LOGIN_RATE_LIMIT_MAX=60
MAX_BACKUP_UPLOAD_MB=1024
SEED_DEFAULTS=false
# When true (default if unset), every server start re-hashes passwords for superadmin@expo.com + scy/it/noc@expo.com to the canonical demo values. Set false only if you must keep custom passwords on those logins.
# ENFORCE_DEFAULT_ACCOUNTS=true

# Deploy tip: run `npm run verify:release` from repo root before go-live.
# See ../DEPLOY_CHECKLIST.md for CORS/cookie/Mongo checks.

# Optional SMTP (forgot-password also uses Portal “Email” on a store if enabled; in NODE_ENV=development
# with no SMTP at all, the API returns a one-time dev_reset_link instead of failing.)
# SMTP_HOST=smtp.gmail.com
# SMTP_PORT=587
# SMTP_EMAIL=your_email@gmail.com
# SMTP_PASSWORD=your_app_specific_password
# FROM_NAME=Expo Stores
