# App VM production example for your VLAN design
# App VM: 10.96.133.197
# DB VM: 10.96.133.213

MONGO_URI=mongodb://user:pass@10.96.133.213:27017/expo-stores
PORT=5000
SESSION_MAX_AGE_MS=2592000000
COOKIE_SECURE=auto
COOKIE_SECRET=replace_with_secure_random_value
EMAIL_CONFIG_ENCRYPTION_KEY=replace_with_64_hex_chars_or_base64_32_bytes
EMERGENCY_RESET_SECRET=disabled_in_production
ENABLE_CSRF=true
# Auth mode: HTTP-only cookies only (JWT is not used)
# Backup mode: mongodump/mongorestore archive flow
# If Web VM serves HTTP use:
CORS_ORIGIN=http://10.96.133.181
# If Web VM serves HTTPS (TLS termination), switch to:
# CORS_ORIGIN=https://10.96.133.181
SEED_DEFAULTS=false

# When SEED_DEFAULTS=true, startup ensures these default accounts exist:
# - superadmin@expo.com => superadmin123
# - scy@expo.com => admin123
# - it@expo.com => admin123
# - noc@expo.com => admin123

# Optional email configuration
SMTP_HOST=smtp.gmail.com
SMTP_PORT=587
SMTP_EMAIL=your_email@gmail.com
SMTP_PASSWORD=your_app_specific_password
FROM_NAME=Expo Stores
